@inherits LayoutComponentBase
@inject ISolderAuthService SolderAuthService
@using Solder.Core.Interfaces.Api.Solder
@implements IDisposable

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="/">
            <span class="brand-mark">S</span>
            <span>Solder</span>
        </a>
        <NavMenu/>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

@code {

    protected override async Task OnInitializedAsync()
    {
        SolderAuthService.SessionChanged += HandleSessionChanged;
        await SolderAuthService.InitializeAsync();
    }

    public void Dispose()
    {
        SolderAuthService.SessionChanged -= HandleSessionChanged;
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

}
