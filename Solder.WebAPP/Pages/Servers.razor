@page "/servers"
@using Solder.Core.Interfaces.Api.Solder
@inject ISolderServerApiService ServerApiService
@inject ISolderAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Servers - Solder</PageTitle>

@if (!AuthService.IsAuthenticatedAsync())
{
    <section class="card">
        <h1>Authentication Required</h1>
        <p style="color: var(--text-muted);">Please sign in to manage your servers.</p>
        <a class="button-link button-primary" href="/auth">Sign In</a>
    </section>
}
else
{
    <section class="card" style="margin-bottom: 1rem;">
        <h1 style="font-size: 2rem; margin-bottom: 0.55rem;">Your Servers</h1>
        <p style="color: var(--text-muted); margin-bottom: 1.5rem;">
            Create and manage your dedicated server instances.
        </p>

        <div style="display: flex; gap: 0.75rem; align-items: flex-end;">
            <div class="field" style="margin-bottom: 0; flex: 1;">
                <label for="new-server-name">New Server Name</label>
                <input id="new-server-name" @bind="_newServerName" placeholder="e.g. My Survival Server"/>
            </div>
            <button class="button-primary" @onclick="CreateServer" disabled="@_isCreating">
                @if (_isCreating)
                {
                    <span>Creating...</span>
                }
                else
                {
                    <span>Create Server</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="message @(_messageIsError ? "error" : "success")">
                @_message
            </div>
        }
    </section>

    @if (_isLoading)
    {
        <div class="loading-progress">
            <svg viewBox="0 0 40 40">
                <circle cx="20" cy="20" r="15"></circle>
                <circle cx="20" cy="20" r="15"></circle>
            </svg>
        </div>
    }
    else if (_servers == null || !_servers.Any())
    {
        <article class="card" style="text-align: center; padding: 3rem 1rem;">
            <p style="color: var(--text-muted); margin-bottom: 0;">You don't have any servers yet. Create one above!</p>
        </article>
    }
    else
    {
        <section class="grid">
            @foreach (var server in _servers)
            {
                <article class="card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <h2 style="margin-bottom: 0.25rem;">@server.ServerName</h2>
                            <code style="font-size: 0.8rem; color: var(--text-muted);">@server.ServerInstanceId</code>
                            <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem;">
                                <a href="/console/@server.ServerInstanceId" class="button-link"
                                   style="padding: 0.3rem 0.6rem; font-size: 0.8rem; border: 1px solid var(--border-color); border-radius: 4px;">Console</a>
                            </div>
                        </div>
                        <button class="button-ghost"
                                style="padding: 0.4rem 0.6rem; color: var(--danger); border-color: transparent;"
                                @onclick="() => DeleteServer(server.ServerInstanceId)">
                            Delete
                        </button>
                    </div>
                </article>
            }
        </section>
    }
}

@code {
    private List<GetServerInstanceResponse>? _servers;
    private string _newServerName = "";
    private string _message = "";
    private bool _messageIsError;
    private bool _isLoading = true;
    private bool _isCreating;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticatedAsync())
        {
            await LoadServers();
        }
        else
        {
            _isLoading = false;
        }
    }

    private async Task LoadServers()
    {
        _isLoading = true;
        try
        {
            var result = await ServerApiService.GetServerInstancesAsync();
            _servers = result.ToList();
        }
        catch (Exception ex)
        {
            _message = "Failed to load servers: " + ex.Message;
            _messageIsError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateServer()
    {
        if (string.IsNullOrWhiteSpace(_newServerName))
        {
            _message = "Please enter a server name.";
            _messageIsError = true;
            return;
        }

        _isCreating = true;
        _message = "";
        try
        {
            await ServerApiService.CreateServerInstance(new CreateServerInstanceRequest(_newServerName));
            _newServerName = "";
            _message = "Server created successfully!";
            _messageIsError = false;
            await LoadServers();
        }
        catch (Exception ex)
        {
            _message = "Failed to create server: " + ex.Message;
            _messageIsError = true;
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task DeleteServer(Guid id)
    {
        try
        {
            await ServerApiService.DeleteServerInstance(new DeleteServerInstanceRequest(id));
            _message = "Server deleted successfully!";
            _messageIsError = false;
            await LoadServers();
        }
        catch (Exception ex)
        {
            _message = "Failed to delete server: " + ex.Message;
            _messageIsError = true;
        }
    }

}
