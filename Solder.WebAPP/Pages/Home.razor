@page "/"

<PageTitle>Solder</PageTitle>

<section class="card" style="margin-bottom: 1rem;">
    <h1 style="font-size: 2rem; margin-bottom: 0.55rem;">Solder User Management</h1>
    <p style="color: var(--text-muted); margin-bottom: 0;">
        Clean frontend for Identity-based account flows in <code>Solder.WebAPI</code> with persisted session state.
    </p>
</section>

<section class="grid">
    <article class="card">
        <h2>Authentication</h2>
        <p style="color: var(--text-muted);">Register or sign in using existing shared DTO contracts.</p>
        <a class="button-link button-primary" href="/auth">Open Sign In</a>
    </article>

    <article class="card">
        <h2>Account</h2>
        <p style="color: var(--text-muted);">Inspect profile info and update email/password.</p>
        <a class="button-link button-ghost" href="/account">Open Account</a>
    </article>
</section>
