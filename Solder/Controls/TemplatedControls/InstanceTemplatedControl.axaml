<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Solder.ViewModels"
        xmlns:templatedControls="clr-namespace:Solder.Controls.TemplatedControls"
        x:DataType="vm:InstanceTemplateViewModel">

    <Style Selector="templatedControls|InstanceTemplatedControl">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="#4A4A4A"
                        CornerRadius="22"
                        ClipToBounds="True"
                        Width="262"
                        Height="262"
                        BorderBrush="#4A4A4A"
                        BorderThickness="2">
                    <Panel>
                        <Grid Name="NormalContent" RowDefinitions="86,*">
                            <Border Grid.Row="0" CornerRadius="22,22,0,0" ClipToBounds="True">
                                <Image Source="avares://Solder/Assets/placeholder.png" Stretch="UniformToFill" />
                            </Border>
                            <Border Grid.Row="1" Padding="11">
                                <StackPanel Spacing="1.5">
                                    <TextBlock Text="{TemplateBinding Name}" Foreground="White" FontSize="16.5"
                                               FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{TemplateBinding Version}" Foreground="#BDBDBD" FontSize="12" />
                                        <TextBlock Text="{Binding Version, StringFormat=' •  MC {0} '}"
                                                   Foreground="#BDBDBD" FontSize="12" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" MaxLines="3" Foreground="White"
                                               FontSize="11" Margin="0,6,0,0" LineHeight="15" />
                                    <TextBlock Text="Last played: 3 days ago" Foreground="#BDBDBD" FontSize="11"
                                               Margin="0,6,0,7.5" />

                                    <Grid ColumnDefinitions="*, Auto">
                                        <Button Grid.Column="0" Background="#54a633" Foreground="White" Height="36"
                                                CornerRadius="18" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Command="{Binding LaunchInstanceCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="7.5">
                                                <TextBlock Text="Launch" VerticalAlignment="Center" FontSize="13.5" />
                                                <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" Width="12" Height="12"
                                                          Foreground="White" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Margin="6,0,0,0" Background="#54a633" Width="36"
                                                Height="36" CornerRadius="18"
                                                Command="{Binding OpenInstanceSettingsCommand}">
                                            <PathIcon
                                                Data="M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.66 4.5,12C4.5,12.34 4.53,12.66 4.57,12.98L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.35 8.52,18.68 9.13,18.93L9.51,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.49,21.58L14.87,18.93C15.48,18.68 16.04,18.35 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5Z"
                                                Width="15" Height="15" Foreground="White" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button Name="AddContent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                IsVisible="False"
                                Command="{Binding CreateInstanceCommand}">

                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="10">
                                <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                          Width="64"
                                          Height="64"
                                          Foreground="#BDBDBD" />
                                <TextBlock Text="Add New Instance"
                                           Foreground="#BDBDBD"
                                           FontSize="16"
                                           FontWeight="Medium" />

                                <ProgressBar IsIndeterminate="False"
                                             IsVisible="{Binding IsBeingCreated}"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding CurrentProgress}"
                                             Width="150"
                                             Height="10"
                                             Margin="0,10,0,0" />
                            </StackPanel>
                        </Button>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="templatedControls|InstanceTemplatedControl[IsAddInstanceCard=True]">
        <Style Selector="^ /template/ Grid#NormalContent">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^ /template/ Button#AddContent">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Setter Property="Cursor" Value="Hand" />
    </Style>
</Styles>