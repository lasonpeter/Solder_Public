<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Solder.ViewModels"
             x:Class="Solder.Controls.UserControl.InstanceSettingsView"
             x:DataType="vm:InstanceSettingsViewModel"
             Width="800" Height="600">

    <Border Background="#2d2d30" CornerRadius="8" BoxShadow="0 10 30 0 #50000000" ClipToBounds="True">
        <Grid ColumnDefinitions="220, *">
            <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="0,0,1,0">
                <ListBox Name="SidebarList" Background="Transparent" BorderThickness="0" Margin="10" SelectedIndex="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="Foreground" Value="#BDBDBD" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Transitions">
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.2" Easing="CircularEaseOut" />
                                    <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                                </Transitions>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="Background" Value="#2A2A2A" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="#3d3d3d" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#3d3d3d" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>
                    </ListBox.Styles>

                    <ListBoxItem Name="ModsTab">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="M3,13H15V15H3V13M3,17H13V19H3V17M3,9H21V11H3V9M3,5H21V7H3V5Z" Width="16" />
                            <TextBlock Text="Mods" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Name="ResourcePacksTab">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon
                                Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M13.96,12.29L11.21,15.83L9.25,13.47L6.5,17H17.5L13.96,12.29Z"
                                Width="16" />
                            <TextBlock Text="Resource Packs" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Name="PerformanceTab">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon
                                Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                                Width="16" />
                            <TextBlock Text="Performance" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <Grid Grid.Column="1" Margin="25" RowDefinitions="*, Auto">

                <DockPanel IsVisible="{Binding #ModsTab.IsSelected}">
                    <TextBlock DockPanel.Dock="Top" Text="Mods" FontSize="22" FontWeight="SemiBold" Foreground="White"
                               Margin="0,0,0,20" />
                    <Grid ColumnDefinitions="*, 150">
                        <Grid RowDefinitions="Auto, *">
                            <Border Grid.Row="0" Background="#3d3d3d" Padding="12,8" CornerRadius="4,4,0,0">
                                <Grid ColumnDefinitions="40, *, 100">
                                    <TextBlock Grid.Column="0" Text="On" FontWeight="Bold" FontSize="12"
                                               Foreground="#BDBDBD" />
                                    <TextBlock Grid.Column="1" Text="Name" FontWeight="Bold" FontSize="12"
                                               Foreground="#BDBDBD" />
                                    <TextBlock Grid.Column="2" Text="Version" FontWeight="Bold" FontSize="12"
                                               Foreground="#BDBDBD" />
                                </Grid>
                            </Border>
                            <ListBox Grid.Row="1" ItemsSource="{Binding ModList}" SelectedItem="{Binding SelectedMod}"
                                     Background="#252526" BorderBrush="#3d3d3d" BorderThickness="1,0,1,1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="40, *, 100" Height="35">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                       Foreground="White" />
                                            <TextBlock Grid.Column="2" Text="{Binding Version}"
                                                       VerticalAlignment="Center" Foreground="#999" FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="8">
                            <Button Content="Add Mod" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            <Button Content="Remove" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                            <Separator Height="10" Background="#333333" />
                            <Button Content="Enable All"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </DockPanel>

                <DockPanel IsVisible="{Binding #ResourcePacksTab.IsSelected}">
                    <TextBlock DockPanel.Dock="Top" Text="Resource Packs" FontSize="22" FontWeight="SemiBold"
                               Foreground="White" Margin="0,0,0,20" />
                    <Grid ColumnDefinitions="*, 150">
                        <ListBox ItemsSource="{Binding ResourcePacks}" SelectedItem="{Binding SelectedResourcePack}"
                                 Background="#252526" BorderThickness="1" BorderBrush="#3d3d3d">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto, *" Margin="5">
                                        <Rectangle Width="48" Height="48" Fill="#3d3d3d" Margin="0,0,12,0" RadiusX="4"
                                                   RadiusY="4" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#999"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="8">
                            <Button Content="Move Up" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            <Button Content="Move Down" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                            <Button Content="Open Folder" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </DockPanel>

                <StackPanel IsVisible="{Binding #PerformanceTab.IsSelected}" Spacing="25">
                    <TextBlock Text="Performance &amp; Java" FontSize="22" FontWeight="SemiBold" Foreground="White" />

                    <HeaderedContentControl>
                        <HeaderedContentControl.Header>
                            <TextBlock Text="Memory Allocation" Foreground="#999" FontSize="12" Margin="0,0,0,5" />
                        </HeaderedContentControl.Header>
                        <Border BorderBrush="#3d3d3d" BorderThickness="1" Padding="20" CornerRadius="8"
                                Background="#252526">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="150, *, 120">
                                    <TextBlock Text="Minimum Memory" VerticalAlignment="Center" Foreground="White" />
                                    <Slider Grid.Column="1" Minimum="512" Maximum="16384" Value="{Binding MinMem}"
                                            Margin="15,0" />
                                    <NumericUpDown Grid.Column="2" Value="{Binding MinMem}" Increment="512"
                                                   FormatString="0 MB" Foreground="White" />
                                </Grid>
                                <Grid ColumnDefinitions="150, *, 120">
                                    <TextBlock Text="Maximum Memory" VerticalAlignment="Center" Foreground="White" />
                                    <Slider Grid.Column="1" Minimum="1024" Maximum="32768" Value="{Binding MaxMem}"
                                            Margin="15,0" />
                                    <NumericUpDown Grid.Column="2" Value="{Binding MaxMem}" Increment="512"
                                                   FormatString="0 MB" Foreground="White" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </HeaderedContentControl>

                    <HeaderedContentControl>
                        <HeaderedContentControl.Header>
                            <TextBlock Text="JVM Arguments" Foreground="#999" FontSize="12" Margin="0,0,0,5" />
                        </HeaderedContentControl.Header>
                        <Border BorderBrush="#3d3d3d" BorderThickness="1" Padding="5" CornerRadius="8"
                                Background="#252526">
                            <TextBox Text="{Binding JvmArgs}" Watermark="Custom Arguments..." Height="120"
                                     AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent"
                                     BorderThickness="0" />
                        </Border>
                    </HeaderedContentControl>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12"
                            Margin="0,25,0,0">
                    <Button Content="Back" Width="100" HorizontalContentAlignment="Center" Padding="0,8"
                            Command="{Binding CloseSettingsCommand}" />
                    <Button Content="Save" Width="100" HorizontalContentAlignment="Center" Background="#4CAF50"
                            Foreground="White" Padding="0,8" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>