<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Solder.ViewModels"
             xmlns:templatedControls1="clr-namespace:Solder.Controls.TemplatedControls"
             x:Class="Solder.Controls.UserControl.Browse"
             x:DataType="vm:BrowseViewModel">

    <Grid RowDefinitions="Auto, *">

        <StackPanel Grid.Row="0" Margin="20, 10">
            <TextBlock Text="Browse Modpacks"
                       HorizontalAlignment="Left"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

            <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search for modpacks..."
                     AcceptsReturn="False"
                     AcceptsTab="False" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ListBox ItemsSource="{Binding  Instances}"
                     Background="Transparent"
                     BorderThickness="0">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="10" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style Selector="^:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="^:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <templatedControls1:ModpackBrowserComponent />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>